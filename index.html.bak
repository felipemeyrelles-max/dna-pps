<script>
/* ===================== CALCULADORA ITCMD =====================
   >>> EDITAR ALÍQUOTAS: objeto ALIQUOTAS_ITCMD. "prog:true" = estado progressivo
   (valor é alíquota representativa única). PERCENTUAL_BASE_PADRAO = base do
   planejamento quando o DIRPF não é informado. */
const ALIQUOTAS_ITCMD = {
  AC:{nome:"Acre",aliquota:4,prog:true}, AL:{nome:"Alagoas",aliquota:4,prog:false},
  AP:{nome:"Amapá",aliquota:4,prog:false}, AM:{nome:"Amazonas",aliquota:2,prog:false},
  BA:{nome:"Bahia",aliquota:8,prog:true}, CE:{nome:"Ceará",aliquota:6,prog:true},
  DF:{nome:"Distrito Federal",aliquota:6,prog:true}, ES:{nome:"Espírito Santo",aliquota:4,prog:false},
  GO:{nome:"Goiás",aliquota:4,prog:true}, MA:{nome:"Maranhão",aliquota:4,prog:false},
  MT:{nome:"Mato Grosso",aliquota:4,prog:true}, MS:{nome:"Mato Grosso do Sul",aliquota:6,prog:false},
  MG:{nome:"Minas Gerais",aliquota:5,prog:false}, PA:{nome:"Pará",aliquota:4,prog:false},
  PB:{nome:"Paraíba",aliquota:8,prog:true}, PR:{nome:"Paraná",aliquota:4,prog:false},
  PE:{nome:"Pernambuco",aliquota:5,prog:false}, PI:{nome:"Piauí",aliquota:4,prog:false},
  RJ:{nome:"Rio de Janeiro",aliquota:8,prog:true}, RN:{nome:"Rio Grande do Norte",aliquota:4,prog:false},
  RS:{nome:"Rio Grande do Sul",aliquota:6,prog:true}, RO:{nome:"Rondônia",aliquota:4,prog:true},
  RR:{nome:"Roraima",aliquota:4,prog:false}, SC:{nome:"Santa Catarina",aliquota:8,prog:true},
  SP:{nome:"São Paulo",aliquota:4,prog:false}, SE:{nome:"Sergipe",aliquota:4,prog:false},
  TO:{nome:"Tocantins",aliquota:4,prog:true}
};
const PERCENTUAL_BASE_PADRAO = 0.20;
const UF_PADRAO = "MG";
const fmtBRL = v => v.toLocaleString("pt-BR",{style:"currency",currency:"BRL"});
const fmtPct = v => (Number.isInteger(v)? v : v.toFixed(1).replace(".",",")) + "%";
const soDig = s => (s||"").replace(/\D/g,"");
const num = s => { const d=soDig(s); return d?parseInt(d,10)/100:0; };
function mask(el){el.addEventListener("input",()=>{const n=num(el.value);el.value=n>0?fmtBRL(n):"";calc();});}
const selUF=document.getElementById("cuf");
Object.keys(ALIQUOTAS_ITCMD).sort((a,b)=>ALIQUOTAS_ITCMD[a].nome.localeCompare(ALIQUOTAS_ITCMD[b].nome,"pt-BR")).forEach(uf=>{
  const o=document.createElement("option");o.value=uf;o.textContent=`${ALIQUOTAS_ITCMD[uf].nome} (${uf}) — ${fmtPct(ALIQUOTAS_ITCMD[uf].aliquota)}`;selUF.appendChild(o);});
selUF.value=UF_PADRAO;
const cv=document.getElementById("cv"),cd=document.getElementById("cd");
mask(cv);mask(cd);selUF.addEventListener("change",calc);
function calc(){
  const merc=num(cv.value),dirpf=num(cd.value),uf=selUF.value,aPct=ALIQUOTAS_ITCMD[uf].aliquota,a=aPct/100;
  const set=(id,t)=>document.getElementById(id).textContent=t;
  if(merc<=0){["ib","ia","ii","pb","pa","pi","ev"].forEach(id=>set(id,"—"));set("ep","");return;}
  const base=dirpf>0?dirpf:merc*PERCENTUAL_BASE_PADRAO,ii=merc*a,pi=base*a,eco=Math.max(ii-pi,0),ep=ii>0?eco/ii*100:0;
  set("ib",fmtBRL(merc));set("ia",fmtPct(aPct));set("ii",fmtBRL(ii));
  set("pb",fmtBRL(base)+(dirpf>0?"":" (estimado)"));set("pa",fmtPct(aPct));set("pi",fmtBRL(pi));
  set("ev",fmtBRL(eco));set("ep",ep>0?`redução de ${fmtPct(Math.round(ep))} no ITCMD`:"");
  var hint=document.getElementById('sim-hint-ebook');
  if(hint) hint.style.display=(merc>0&&merc<500000)?'flex':'none';
}
cv.value=fmtBRL(4000000);cd.value=fmtBRL(800000);calc();

/* ===================== FORM (stub p/ CRM — etapa futura) ===================== */
/* ===================== POPUP QUALIFICAÇÃO ===================== */
function openModal(){
  document.getElementById('qpopup').classList.add('open');
  document.body.style.overflow='hidden';
}
function closeModal(){
  document.getElementById('qpopup').classList.remove('open');
  document.body.style.overflow='';
  document.getElementById('qform-wrap').style.display='';
  document.getElementById('qthanks-padrao').style.display='none';
  document.getElementById('qthanks-ebook').style.display='none';
  document.getElementById('qform').reset();
  document.querySelectorAll('.qrlabel').forEach(function(l){l.classList.remove('sel');});
  document.querySelectorAll('.qerr').forEach(function(e){e.style.display='none';});
  document.querySelectorAll('.qfield input').forEach(function(i){i.classList.remove('err');});
  document.getElementById('qbtn').disabled=false;
  document.getElementById('qbtn').textContent='Quero meu diagnóstico gratuito →';
}
document.getElementById('qpopup').addEventListener('click',function(e){if(e.target===this)closeModal();});
document.addEventListener('keydown',function(e){if(e.key==='Escape')closeModal();});
document.querySelectorAll('.qrlabel input[type=radio]').forEach(function(r){
  r.addEventListener('change',function(){
    document.querySelectorAll('.qrlabel').forEach(function(l){l.classList.remove('sel');});
    this.closest('.qrlabel').classList.add('sel');
  });
});
document.getElementById('qtel').addEventListener('input',function(){
  var v=this.value.replace(/\D/g,'').slice(0,11);
  if(v.length>10)v=v.replace(/^(\d{2})(\d{5})(\d{4}).*/,'($1) $2-$3');
  else if(v.length>6)v=v.replace(/^(\d{2})(\d{4})(\d*)/,'($1) $2-$3');
  else if(v.length>2)v=v.replace(/^(\d{2})(\d*)/,'($1) $2');
  this.value=v;
});
document.getElementById('qform').addEventListener('submit',function(ev){
  ev.preventDefault();
  var nome=document.getElementById('qnome').value.trim();
  var tel=document.getElementById('qtel').value.trim();
  var email=document.getElementById('qemail').value.trim();
  var pat=document.querySelector('input[name=patrimonio]:checked');
  var ok=true;
  document.querySelectorAll('.qerr').forEach(function(e){e.style.display='none';});
  document.querySelectorAll('.qfield input').forEach(function(i){i.classList.remove('err');});
  if(!nome){document.getElementById('qnome-err').style.display='block';document.getElementById('qnome').classList.add('err');ok=false;}
  var td=tel.replace(/\D/g,'');
  if(td.length<10||td.length>11){document.getElementById('qtel-err').style.display='block';document.getElementById('qtel').classList.add('err');ok=false;}
  if(!email||!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)){document.getElementById('qemail-err').style.display='block';document.getElementById('qemail').classList.add('err');ok=false;}
  if(!pat){document.getElementById('qpatrimonio-err').style.display='block';ok=false;}
  if(!ok)return;
  var btn=document.getElementById('qbtn');
  btn.disabled=true;btn.textContent='Enviando...';
  var pv=pat.value;
  var ctx=pv==='menos500k'?'Faixa patrimônio: Menos de R$500k':pv==='500k2M'?'Faixa patrimônio: R$500k a R$2M':'Faixa patrimônio: Acima de R$2M';
  // Dispara pixel/CAPI apenas para leads qualificados (>=500k) — não desperdiça otimização com leads ebook
  if(pv!=='menos500k'){
    sendCapi('Lead',{});
    window.dataLayer=window.dataLayer||[];
    window.dataLayer.push({event:'lead_qualified',patrimonio_faixa:pv});
  } else {
    window.dataLayer=window.dataLayer||[];
    window.dataLayer.push({event:'lead_ebook',patrimonio_faixa:'menos500k'});
  }
  fetch('https://crm.mck.agenciaever.cloud/api/leads/publico',{
    method:'POST',
    headers:{'Content-Type':'application/json'},
    body:JSON.stringify({formulario_slug:pv==='menos500k'?'dna_pps_ebook':'dna_pps',nome:nome,whatsapp:tel,email:email,contexto:ctx,landing_page:window.location.href})
  }).catch(function(){}).finally(function(){
    document.getElementById('qform-wrap').style.display='none';
    if(pv==='acima2M'){
      var msgA=encodeURIComponent('Olá! Me chamo '+nome+'. Tenho interesse em planejamento patrimonial e meu patrimônio é acima de R$2 milhões.');
      window.open('https://api.whatsapp.com/send?phone=553599667294&text='+msgA,'_blank');
      document.getElementById('qthanks-padrao').style.display='block';
    } else if(pv==='500k2M'){
      var msgB=encodeURIComponent('Olá! Me chamo '+nome+'. Tenho interesse em planejamento patrimonial e meu patrimônio está entre R$500k e R$2 milhões.');
      window.open('https://api.whatsapp.com/send?phone=553599667294&text='+msgB,'_blank');
      document.getElementById('qthanks-padrao').style.display='block';
    } else {
      document.getElementById('qthanks-ebook').style.display='block';
    }
  });
});

/* ===================== ANIMAÇÕES DE SCROLL (reveal + parallax) ===================== */
(function(){
  const sel = "h1,.hero p,.hero .btn,.media-row h2,.media-row p,.media-row .btn,.media-row .media,.pilares h2,.pilares li,.pilares .vid,.sol-head,.card,.sim-title,.calc-form,.calc-result,.eco,.sim-cta,.quem h2,.quem p,.dir,.parc h3,.parc img,.formgrid h2,.formgrid p,.lead-form,.ft-logo";
  const els = document.querySelectorAll(sel);
  els.forEach(el=>el.classList.add("reveal"));
  // stagger por grupo
  [".cards .card",".dirs .dir",".pilares li"].forEach(g=>{
    document.querySelectorAll(g).forEach((el,i)=>el.style.transitionDelay=(i*0.09)+"s");
  });
  const io = new IntersectionObserver((ents)=>{
    ents.forEach(e=>{ if(e.isIntersecting){ e.target.classList.add("in"); io.unobserve(e.target); } });
  },{threshold:0.12, rootMargin:"0px 0px -7% 0px"});
  els.forEach(el=>io.observe(el));
  // parallax sutil no vídeo do hero
  const hv = document.querySelector(".hero video");
  if(hv){
    let raf=false;
    addEventListener("scroll",()=>{
      if(raf) return; raf=true;
      requestAnimationFrame(()=>{ const y=Math.min(scrollY,900); hv.style.transform="scale(1.06) translateY("+(y*0.06)+"px)"; raf=false; });
    },{passive:true});
    hv.style.transform="scale(1.06)";
  }
})();
</script>
</body>
</html>
