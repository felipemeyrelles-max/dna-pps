fbq('init','1922595521595366');
fbq('track','PageView');
function sendCapi(eventName,userData){
  var eid='ev_'+Date.now()+'_'+Math.random().toString(36).slice(2,8);
  fbq('track',eventName,{},{eventID:eid});
  fetch('/api/capi',{method:'POST',headers:{'Content-Type':'application/json'},
    body:JSON.stringify({event_name:eventName,event_id:eid,
      event_source_url:window.location.href,user_data:userData||{}})
  }).catch(function(){});
}
document.addEventListener('DOMContentLoaded',function(){
  document.querySelectorAll('a[href*="553599"],a[href*="wa.me"],.whatsapp-float').forEach(function(el){
    el.addEventListener('click',function(){sendCapi('Contact',{});});
  });
});
</script>
